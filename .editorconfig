root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

[*.s]
indent_style = tab
tab_width = 8

[*.ld]
indent_style = tab
tab_width = 8

[*.yaml]
tab_width = 2

[*.md]
tab_width = 2

[{CMakeLists.txt,*.cmake{,.in}}]
tab_width = 2

[.{clang-format,clang-tidy}]
tab_width = 2

[grub.cfg{,.in}]
indent_style = tab
tab_width = 8
