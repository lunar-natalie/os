# CMake-configured Doxygen configuration.

# Configured properties
PROJECT_NAME            = @DOXYGEN_PROJECT_NAME@
OUTPUT_DIRECTORY        = @DOXYGEN_OUTPUT_DIRECTORY@
INPUT                   = @DOXYGEN_INPUT_FILES@
USE_MDFILE_AS_MAINPAGE  = @DOXYGEN_MAINPAGE@
STRIP_FROM_PATH         = @DOXYGEN_STRIP_FROM_PATH@
STRIP_FROM_INC_PATH     = @DOXYGEN_STRIP_FROM_PATH@

# Options
GENERATE_LATEX          = NO
SHOW_USED_FILES         = NO
WARN_IF_UNDOCUMENTED    = NO

# Preprocessor
ENABLE_PREPROCESSING    = YES
MACRO_EXPANSION         = YES
EXPAND_ONLY_PREDEF      = YES
PREDEFINED              = __attribute__(x)=

# External stylesheet configuration
@DOXYGEN_STYLE_CONFIG@
